/*---------------------------------------------------------------------------*\
  kinematicCloudProperties — oilWaterAirParticleFoam
  Mineral particle (d=3.5e-5 m = 0.035 mm, rho=2500 kg/m³) inside an air bubble.

  Force model rationale
  ─────────────────────
  gravity        : omitted — constant/g = (0 9.81 0) in this case points up,
                   which would push the dense particle upward (wrong).
                   Net gravitational settling is already encoded in the
                   p_rgh pressure field via rho*(g & h).
  sphereDrag     : Schiller-Naumann drag — dominant restoring force.
  pressureGradient: provides bubble-wake suction (rho_f * V_p * DU_f/Dt).
  virtualMass    : added-mass entrainment (Cvm=0.5 for sphere).

  Size (updated for the shrunk bubble geometry — see system/setFieldsDict)
  ──────────────────────────────────────────────────────────────────────
  Whole-geometry scale factor applied: 0.07 (bubble radius 5 mm -> 0.35 mm).
  Particle diameter scaled proportionally: d = 5e-4 m (0.5 mm) -> 3.5e-5 m
  (0.035 mm), preserving the original size ratio:
    d_p / d_bubble = 0.5 mm / 10 mm   = 0.05  (before shrink)
    d_p / d_bubble = 0.035 mm / 0.7 mm = 0.05  (after shrink, unchanged)
  This keeps the particle a fine mineral speck well below the bubble
  diameter, consistent with a flotation-type setup. If a coarser mesh needs
  a larger, more numerically robust particle, increase "value" below and
  rescale the bubble/oil geometry in system/setFieldsDict to keep this ratio.
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      kinematicCloudProperties;
}

solution
{
    active          true;
    coupled         no;
    transient       yes;
    cellValueSourceCorrection no;
    maxCo           0.3;

    sourceTerms     { schemes { U explicit 1; } }

    interpolationSchemes
    {
        rho         cell;
        U           cellPoint;
        muc         cell;
        p           cell;
        DUcDt       cell;
    }

    integrationSchemes { U analytical; }
}

constantProperties
{
    rho0            2500;       // [kg/m³] mineral particle density
}

subModels
{
    particleForces
{
    sphereDrag;
    //gravity;                        // omitted here too — see header note
                                        // above: g points up in this case, so
                                        // applying it directly would add a wrong
                                        // upward force; settling is already
                                        // captured via p_rgh.
    pressureGradient { U U; }
    virtualMass      { Cvm 0.5; }
}

    injectionModels
    {
        model1
        {
            type            manualInjection;
            SOI             0;
            massTotal       0;
            parcelBasisType fixed;
            nParticle       1;
            positionsFile   "kinematicCloudPositions";
            U0              (0 0 0);

            sizeDistribution
{
    type fixedValue;
    fixedValueDistribution
    {
        value   3.5e-5;   // 0.035 mm — shrunk by factor 0.07 to match new 0.35mm bubble
    }
}
        }
    }

    dispersionModel             none;
    patchInteractionModel       standardWallInteraction;
    stochasticCollisionModel    none;
    surfaceFilmModel            none;

    standardWallInteractionCoeffs
    {
        type    rebound;
        e       0.9;
        mu      0.1;
    }
}

cloudFunctions {}

