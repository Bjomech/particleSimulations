FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;   // 1st-order implicit time stepping
}

gradSchemes
{
    default         Gauss linear;
    grad(U)         Gauss linear;
}

divSchemes
{
    default             none;   // force every div() term to be listed explicitly

    div(rhoPhi,U)       Gauss limitedLinear 1;   // momentum convection

    // Bounded (0..1) advection of each phase fraction; isoAdvector
    // (reconstructionScheme isoAlpha, see fvSolution) does the actual
    // geometric advection in this solver — these vanLeer schemes are the
    // divSchemes entry OpenFOAM's alphaEqn machinery still looks up, even
    // though the isoAdvector path does not directly evaluate div(phi,alpha.X)
    // the way a MULES-based solver would.
    div(phi,alpha.air)   Gauss vanLeer;
    div(phi,alpha.oil)   Gauss vanLeer;
    div(phi,alpha.water) Gauss vanLeer;
    div(phi,alpha)       Gauss vanLeer;

    div((muEff*dev(T(grad(U))))) Gauss linear;   // viscous stress term in UEqn.H

    // Interface-normal-vector terms used for surface tension / curvature
    // reconstruction (threePhaseInterfaceProperties.C).
    div((grad(alpha.air)|(mag(grad(alpha.air))+small)))   Gauss linear;
    div((grad(alpha.oil)|(mag(grad(alpha.oil))+small)))   Gauss linear;
    div((grad(alpha.water)|(mag(grad(alpha.water))+small))) Gauss linear;
    div(nHat)           Gauss linear;

}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

fluxRequired
{
    default         no;
    p_rgh;      // pressure needs a consistent flux for the PISO/PIMPLE loop
    "alpha.*";  // phase fractions need it for the isoAdvector/VOF interface reconstruction
}

